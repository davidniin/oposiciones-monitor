# Copia este archivo como .env y rellena los valores.
# Para GitHub Actions, configura cada uno como secret en Settings -> Secrets and variables -> Actions.

# Clave API de Resend (https://resend.com/api-keys)
# Se obtiene gratis registrandose en resend.com. Empieza por re_
RESEND_API_KEY=

# Email de destino donde llegaran los avisos de nuevas oposiciones
RECIPIENT_EMAIL=

# Email del usuario tecnico, recibira alertas solo si hay 3 fallos consecutivos del scraper
TECH_EMAIL=
